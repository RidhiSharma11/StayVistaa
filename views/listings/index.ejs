<% layout("/layouts/boilerplate") %>
  <style>

.listing-card{
  height:100%;
  display:flex;
  flex-direction:column;
}

.card-body{
  flex-grow:1;
}

.listing-img{
  height:20rem;
  object-fit:cover;
}

.card-title{
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}


.listing-card{
  transition:0.3s;
}

.listing-card:hover{
  transform:translateY(-6px);
  box-shadow:0 10px 25px rgba(0,0,0,0.15);
}

#filters{
  display:flex;
  gap:30px;
  padding:20px 10px;
  overflow-x:auto;
  white-space:nowrap;
  border-bottom:1px solid #eee;
  margin-bottom:20px;
  scrollbar-width:none; 
}

#filters::-webkit-scrollbar{
  display:none; 
}

.filter{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  min-width:70px;
  opacity:0.7;
  transition:all 0.3s ease;
  padding:10px;
  border-radius:12px;
}
.filter.active{
  opacity:1;
  border-bottom:3px solid #ff385c;
}

.filter i{
  font-size:22px;
  margin-bottom:6px;
  color:#555;
}

.filter p{
  font-size:0.8rem;
  margin:0;
}

.filter:hover{
  opacity:1;
  cursor:pointer;
  transform:translateY(-3px);
  background:#f7f7f7;
}

#filters{
  display:flex;
  gap:30px;
  padding:20px 10px;
  overflow-x:auto;
  border-bottom:1px solid #eee;
}

.filter{
  text-align:center;
  min-width:70px;
  padding:10px;
  border-radius:12px;
  transition:0.3s;
  opacity:0.8;
}

.filter i{
  font-size:22px;
  margin-bottom:6px;
}

.filter:hover{
  opacity:1;
  background:#f7f7f7;
  transform:translateY(-3px);
  cursor:pointer;
}

.trending i{ color:#ff5733; }
.room i{ color:#4a90e2; }
.cities i{ color:#8e44ad; }
.pools i{ color:#00bcd4; }
.mountains i{ color:#2ecc71; }
.camping i{ color:#f39c12; }
.farms i{ color:#8d6e63; }
.snow i{ color:#5dade2; }
.ships i{ color:#1abc9c; }
.domes i{ color:#d4af37; }


  </style>

<div id="filters">
    <div class="filter trending">
      <i class="fa-solid fa-fire"></i>
      <p>Trending</p>
    </div>

    <div class="filter room">
      <i class="fa-solid fa-bed"></i>
      <p>Room</p>
    </div>

    <div class="filter cities">
      <i class="fa-solid fa-city"></i>
      <p>Iconic cities</p>
    </div>

    <div class="filter pools">
      <i class="fa-solid fa-person-swimming"></i>
      <p>Amazing pools</p>
    </div>

    <div class="filter mountains">
      <i class="fa-solid fa-mountain"></i>
      <p>Mountains</p>
    </div>

    <div class="filter camping">
      <i class="fa-solid fa-tent"></i>
      <p>Camping</p>
    </div>

    <div class="filter farms">
      <i class="fa-solid fa-cow"></i>
      <p>Farms</p>
    </div>

    <div class="filter snow">
      <i class="fa-regular fa-snowflake"></i>
      <p>Snow</p>
    </div>

    <div class="filter ships">
      <i class="fa-solid fa-ship"></i>
      <p>Ships</p>
    </div>

    <div class="filter domes">
      <i class="fa-solid fa-landmark-dome"></i>
      <p>Domes</p>
    </div>
</div>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
<% for(let listing of allListings){ %>
<div class="col mb-4 d-flex">
  <a href="/listings/<%= listing._id %>" class="listing-link w-100">
  <div class="card listing-card h-100">
  <img src="<%= listing.image.url %>" 
    class="card-img-top listing-img" 
     alt="listing_image">
     <div class="card-body">
     <p class="card-text">
     <b class="card-title"><%= listing.title %></b><br/>
      &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
     </p>
    </div>
  </div>
  </a>
   </div>
<% } %>
  </div>