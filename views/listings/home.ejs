<% layout("/layouts/boilerplate") %>

<section class="hero">
  <div class="hero-content">
    <h1>Discover <span class="highlight">luxury</span> stays</h1>
    <p>Luxury villas, cozy retreats & unforgettable experiences.</p>
    <div class="hero-buttons">
      <a href="/listings" id ="button" > <b> Explore Stays </b></a>
      <a href="/listings/new" id="button"> <b> Become a Host </b></a>
    </div>
  </div>
</section>


<section class="about-section">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-6 mb-4">
        <img 
          src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2"
          class="img-fluid about-img"
          alt="Luxury stay">
      </div>
      <div class="col-md-6">
        <h2 class="about-title">About EliteVistaa</h2>

        <p class="about-text">
          EliteVistaa is a premium platform designed to help travelers
          discover unique and luxurious stays across the world.
        </p>

        <p class="about-text">
          From modern city apartments to peaceful mountain retreats,
          EliteVistaa connects guests with unforgettable travel
          experiences and comfortable living spaces.
        </p>

        <a href="/listings" class="btn1">
          Explore Stays
        </a>
      </div>
    </div>
  </div>
</section>


<section class="reviews">
<h2 class="text-center mb-5">What Our Guests Say</h2>

<div id="reviewCarousel" class="carousel slide container" data-bs-ride="carousel" data-bs-interval="3000">

<div class="carousel-inner">

<div class="carousel-item active">
<div class="review-card text-center p-4">

<img src="https://randomuser.me/api/portraits/women/44.jpg" class="review-img">

<p class="review-text">
The villa was absolutely stunning! Booking through EliteVistaa was smooth and easy.
</p>

<div class="stars">★★★★★</div>

<h5>Priya Sharma</h5>

</div>
</div>

<div class="carousel-item">
<div class="review-card text-center p-4">

<img src="https://randomuser.me/api/portraits/men/32.jpg" class="review-img">

<p class="review-text">
Beautiful listings and amazing service. Loved our stay in Manali!
</p>

<div class="stars">★★★★★</div>

<h5>Rahul Mehta</h5>

</div>
</div>

<div class="carousel-item">
<div class="review-card text-center p-4">

<img src="https://randomuser.me/api/portraits/women/65.jpg" class="review-img">

<p class="review-text">
A fantastic platform to discover luxury stays. Highly recommended!
</p>

<div class="stars">★★★★★</div>

<h5>Ananya Kapoor</h5>

</div>
</div>

</div>

<button class="carousel-control-prev" type="button" data-bs-target="#reviewCarousel" data-bs-slide="prev">
<span class="carousel-control-prev-icon"></span>
</button>

<button class="carousel-control-next" type="button" data-bs-target="#reviewCarousel" data-bs-slide="next">
<span class="carousel-control-next-icon"></span>
</button>

</div>
</section>

<section class="featured">
  <h2>Popular Stays</h2>
  <div class="featured-cards">
    <div class="card">
      <img src="https://media-cdn.tripadvisor.com/media/photo-s/31/80/70/6a/premier-rooms-with-semi.jpg">
      <h3>Luxury Villa</h3>
      <p>₹12,000 / night</p>
    </div>
    <div class="card">
      <img src="https://images.squarespace-cdn.com/content/v1/615f0e0c67cbd55a7753a1cd/1641580518678-GNN28ESTI40ILYC10AZ1/IMG_2285.JPG">
      <h3>Cozy Cabin</h3>
      <p>₹6,000 / night</p>
    </div>
    <div class="card">
      <img src="https://a0.muscache.com/im/pictures/prohost-api/Hosting-48246770/original/6cdeb0e7-efbd-49f6-b202-a07181f8990f.jpeg?im_w=720">
      <h3>Beach House</h3>
      <p>₹9,500 / night</p>
    </div>
  </div>
</section>

<section class="host">
  <h2>Earn by Hosting</h2>
  <p>List your property and start earning with StayVistaa.</p>
  <a href="/listings/new" class = "btn1">Become a Host</a>
</section>